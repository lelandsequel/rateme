# RATE ME — environment variables.
# Copy this file to `.env` and fill in values. The app degrades gracefully:
# when DATABASE_URL is empty, the app boots in mock mode (no DB, no auth).

# ---- Database ----------------------------------------------------------
# When unset, the app uses src/lib/mock.ts everywhere (HAS_DB=false).
# For local SQLite dev: DATABASE_URL="file:./prisma/dev.db"
# For Neon (Postgres):  DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME"
DATABASE_URL=

# ---- Auth.js v5 --------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Override the inferred URL when deployed behind a proxy / on a custom host.
AUTH_URL=http://localhost:3000

# ---- Notes -------------------------------------------------------------
# Demo seed credentials (after `npx prisma db seed`): admin@demo.com / demo123
# Mock-mode demo credentials (no DB):                  admin@demo.com / demo123
