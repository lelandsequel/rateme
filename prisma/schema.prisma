// RMR (Rate My Rep) — third-party rating marketplace.
//
// Core idea: Raters (customers/buyers) rate Reps (sales reps). Data is
// owned by the individual, portable across employers. Managers can view
// teams of either Reps OR Raters. Connections gate ratings — you can
// only rate a Rep you're connected to. No free text — only structured
// 1-5 scores + a binary "would-take-call-again" flag.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

enum Role {
  REP             // a sales rep being rated
  RATER           // a customer/buyer who rates reps
  SALES_MANAGER   // manages a team of reps
  RATER_MANAGER   // manages a team of raters
  ADMIN           // platform admin
}

enum USState {
  AL
  AK
  AZ
  AR
  CA
  CO
  CT
  DE
  FL
  GA
  HI
  ID
  IL
  IN
  IA
  KS
  KY
  LA
  ME
  MD
  MA
  MI
  MN
  MS
  MO
  MT
  NE
  NV
  NH
  NJ
  NM
  NY
  NC
  ND
  OH
  OK
  OR
  PA
  RI
  SC
  SD
  TN
  TX
  UT
  VT
  VA
  WA
  WV
  WI
  WY
  DC
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  passwordHash     String
  role             Role
  state            USState
  avatarUrl        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastLoginAt      DateTime?
  // null = email is unverified. Set when the user clicks a verify link.
  // Existing seeded users are grandfathered (set in seed.ts) so demo
  // accounts keep working even if REQUIRE_EMAIL_VERIFICATION is on.
  emailVerifiedAt  DateTime?
  authTokens       AuthToken[]

  // 1:1 child profile rows (only one populated per user, matching role).
  repProfile     RepProfile?
  raterProfile   RaterProfile?
  managerProfile ManagerProfile?

  // Connections this user is involved in (either side).
  repConnections   Connection[] @relation("ConnectionRep")
  raterConnections Connection[] @relation("ConnectionRater")

  // Ratings authored or received.
  ratingsGiven     Rating[] @relation("RatingFromRater")
  ratingsReceived  Rating[] @relation("RatingForRep")

  // Rating requests this user initiated or is the target rep of.
  requestsInitiated RatingRequest[] @relation("RequestInitiator")
  requestsAsTarget  RatingRequest[] @relation("RequestForRep")

  // Push notification tokens (one user, many devices).
  pushTokens PushToken[]

  // Manager → team member assignments. A manager has many teamMembers;
  // a member has at most one team manager active at a time.
  managedMemberships  TeamMembership[] @relation("MembershipManager")
  membershipAsMember  TeamMembership?  @relation("MembershipMember")

  // Favorites — Raters can mark Reps as favorites to receive notifications
  // whenever the Rep gets a new rating. Two-sided relation: as the watching
  // rater, and as the watched rep.
  favoritesAsRater   Favorite[]        @relation("FavoriteRater")
  favoritedByRaters  Favorite[]        @relation("FavoriteRep")

  // In-app + cross-channel notification log (push/email tracked here too).
  notifications      NotificationLog[]

  @@index([role])
  @@index([state])
}

// Sales rep profile. Public fields visible to any rater.
model RepProfile {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String   // e.g. "Senior Account Executive"
  company    String   // current employer (portable — changing is allowed)
  industryId String
  industry   Industry @relation(fields: [industryId], references: [id])
  metroArea  String?  // e.g. "Houston, TX" — free-form for now

  @@index([industryId])
  @@index([company])
}

// Rater profile. Privacy: ONLY title + company are publicly visible.
// Email + name are NOT shown to reps; reps see "Title @ Company" only.
model RaterProfile {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String   // PUBLIC — e.g. "VP of Procurement"
  company    String   // PUBLIC
  industryId String
  industry   Industry @relation(fields: [industryId], references: [id])

  @@index([industryId])
  @@index([company])
}

enum ManagerType {
  REP_MANAGER     // manages a team of REPs (a sales manager)
  RATER_MANAGER   // manages a team of RATERs
}

model ManagerProfile {
  userId     String      @id
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  managesType ManagerType
  company    String      // their employer

  @@index([company])
}

// Industry lookup — curated list, seeded. RepProfile + RaterProfile both FK here.
model Industry {
  id           String         @id @default(cuid())
  name         String         @unique
  slug         String         @unique
  reps         RepProfile[]
  raters       RaterProfile[]

  @@index([slug])
}

// ---------------------------------------------------------------------------
// Connections — required before a rater can rate a rep.
// ---------------------------------------------------------------------------

enum ConnectionStatus {
  PENDING       // awaiting confirmation by the OTHER side
  ACCEPTED
  REJECTED
  DISCONNECTED  // was accepted, then either side disconnected
}

enum ConnectionInitiator {
  REP
  RATER
}

model Connection {
  id           String              @id @default(cuid())
  repUserId    String
  rep          User                @relation("ConnectionRep", fields: [repUserId], references: [id], onDelete: Cascade)
  raterUserId  String
  rater        User                @relation("ConnectionRater", fields: [raterUserId], references: [id], onDelete: Cascade)
  initiatedBy  ConnectionInitiator
  status       ConnectionStatus    @default(PENDING)
  requestedAt  DateTime            @default(now())
  respondedAt  DateTime?
  ratings      Rating[]

  @@unique([repUserId, raterUserId])
  @@index([repUserId, status])
  @@index([raterUserId, status])
}

// ---------------------------------------------------------------------------
// Ratings — 5 structured dimensions + an optional review comment.
// "Free text" per the original spec means user-to-user direct messaging
// (which we don't allow) — review comments tied to a rating ARE fine.
// ---------------------------------------------------------------------------

model Rating {
  id                  String     @id @default(cuid())
  connectionId        String
  connection          Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  // Denormalized for fast leaderboards / status calcs.
  repUserId           String
  rep                 User       @relation("RatingForRep", fields: [repUserId], references: [id], onDelete: Cascade)
  raterUserId         String
  rater               User       @relation("RatingFromRater", fields: [raterUserId], references: [id], onDelete: Cascade)

  // The five 1-5 dimensions. Stored as Int with CHECK in app code.
  responsiveness      Int
  productKnowledge    Int
  followThrough       Int
  listeningNeedsFit   Int
  trustIntegrity      Int

  // Binary brutal-honesty flag.
  takeCallAgain       Boolean

  // Optional review comment (≤500 chars enforced in route handlers).
  // Per-rating review text — NOT a chat / DM channel.
  comment             String?

  // Optional source: was this rating fulfilled via a RatingRequest?
  ratingRequestId     String?    @unique
  ratingRequest       RatingRequest? @relation(fields: [ratingRequestId], references: [id])

  createdAt           DateTime   @default(now())

  @@index([repUserId, createdAt])
  @@index([raterUserId, createdAt])
}

// ---------------------------------------------------------------------------
// Rating Requests — explicit asks for a rating, with rate-limiting.
//
// Two flavors:
//   ONE_TIME   — rep sends a one-shot request to a NON-USER email; if the
//                rater accepts, they sign up + connect + rate in one flow.
//   ON_BEHALF  — manager requests a rating on behalf of a rep, targeting
//                an existing connected rater. Limit: one per (rep, rater)
//                pair every 30 days.
// ---------------------------------------------------------------------------

enum RatingRequestType {
  ONE_TIME
  ON_BEHALF
}

enum RatingRequestStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELLED
}

model RatingRequest {
  id                String              @id @default(cuid())
  type              RatingRequestType
  status            RatingRequestStatus @default(PENDING)

  forRepUserId      String
  forRep            User                @relation("RequestForRep", fields: [forRepUserId], references: [id], onDelete: Cascade)

  // Who fired the request. For ONE_TIME this is usually the rep themselves;
  // for ON_BEHALF it's a SALES_MANAGER user.
  initiatedByUserId String
  initiatedBy       User                @relation("RequestInitiator", fields: [initiatedByUserId], references: [id], onDelete: Cascade)

  // For ONE_TIME: the email we sent the invite to (may not yet be a user).
  // For ON_BEHALF: null (target is the connected rater).
  toEmail           String?
  toRaterUserId     String?  // populated when ON_BEHALF or after a ONE_TIME signup links

  expiresAt         DateTime
  createdAt         DateTime            @default(now())
  completedAt       DateTime?

  rating            Rating?

  @@index([forRepUserId, status])
  @@index([toEmail])
}

// ---------------------------------------------------------------------------
// Manager team membership.
//   - SALES_MANAGER → many REP members
//   - RATER_MANAGER → many RATER members
// One membership row per (manager, member) pair. A member has at most one
// active membership; the @@unique enforces it via the optional active flag.
// ---------------------------------------------------------------------------

model TeamMembership {
  id          String   @id @default(cuid())
  managerId   String
  manager     User     @relation("MembershipManager", fields: [managerId], references: [id], onDelete: Cascade)
  memberId    String   @unique
  member      User     @relation("MembershipMember", fields: [memberId], references: [id], onDelete: Cascade)
  invitedAt   DateTime @default(now())
  acceptedAt  DateTime?
  endedAt     DateTime?

  @@index([managerId])
}

// ---------------------------------------------------------------------------
// Push tokens (Expo) — carried over from the prior schema.
// ---------------------------------------------------------------------------

model PushToken {
  id          String    @id @default(cuid())
  token       String    @unique
  platform    String    @default("expo")
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime  @default(now()) @updatedAt

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Favorites — a Rater "watches" a Rep. When a watched Rep gets a new rating
// from anyone, every watching Rater gets a push + email notification. The
// rater identity is NEVER leaked to a third party in the notification body
// (the rep is the named subject; the rater is anonymous to the world).
// ---------------------------------------------------------------------------

model Favorite {
  id          String   @id @default(cuid())
  raterUserId String
  rater       User     @relation("FavoriteRater", fields: [raterUserId], references: [id], onDelete: Cascade)
  repUserId   String
  rep         User     @relation("FavoriteRep", fields: [repUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([raterUserId, repUserId])
  @@index([repUserId])  // fan-out lookup on rating-create
  @@index([raterUserId])
}

// ---------------------------------------------------------------------------
// NotificationLog — append-only record of notifications fanned out by the
// app. The `payload` field is a JSON blob the app reads back for an in-app
// inbox; pushSent/emailSent record best-effort outbound delivery.
// ---------------------------------------------------------------------------

model NotificationLog {
  id           String   @id @default(cuid())
  userId       String   // recipient
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind         String   // "favorite-rating" for now
  payload      String   // JSON blob, app-readable
  pushSent     Boolean  @default(false)
  emailSent    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// AuthToken — single-use, short-lived tokens for password reset + email
// verification. We store ONLY the sha256 hash of the raw token; the raw
// token lives only in the URL we email. Compare hashes on consume.
// ---------------------------------------------------------------------------

model AuthToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       String    // "password-reset" | "email-verify"
  tokenHash  String    @unique  // sha256 of the raw token; never store raw
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, kind])
}
